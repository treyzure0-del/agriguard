# ============================================
# AgriGuard AI — Environment Configuration
# ============================================
# Copy this file to .env and fill in your key
# cp .env.example .env  (Mac/Linux)
# copy .env.example .env  (Windows)

# ---- CHOOSE YOUR AI PROVIDER ----
# Options: gemini | openai | deepseek
AI_PROVIDER=gemini

# ---- GOOGLE GEMINI (FREE) ----
# Get free key: https://aistudio.google.com
# Click "Get API Key" then "Create API key in new project"
GEMINI_API_KEY=AIzaSyCMz3e9lb3ke3fkwQiaui8Chv1B8C_5d84

# ---- OPENAI (PAID - BEST QUALITY) ----
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=paste_your_openai_key_here

# ---- DEEPSEEK (PAID - CHEAPEST) ----
# Get key: https://platform.deepseek.com
# $5 credit lasts months for a small project
DEEPSEEK_API_KEY=

# ---- SERVER CONFIG ----
PORT=3000
DATABASE_PATH=./agriguard.db
